        "function_name": "simulate_user_turn"
      }
    },
    {
      "name": "chatbot",
      "handler": {
        "module_path": "examples_py.chatbot_simulation_evaluation.agent_simulation_evaluation.nodes",
        "function_name": "chatbot_turn"
      }
    },
    {
      "name": "evaluator",
      "handler": {
