{
  "graph_id": "langsmith-agent-simulation-evaluation",
  "version": "1.0.0",
  "settings": {
    "telemetry": {
      "enabled": true,
      "provider": "langsmith"
    }
  },
  "state_definition": {
    "type": "typed_dict",
    "module_path": "examples_py.chatbot_simulation_evaluation.langsmith_agent_simulation_evaluation.state",
    "class_name": "SimulationState"
  },
  "nodes": [
    {
      "name": "simulated_user",
      "handler": {
        "module_path": "examples_py.chatbot_simulation_evaluation.langsmith_agent_simulation_evaluation.nodes",
        "function_name": "simulate_user_turn"
      }
    },
    {
      "name": "chatbot",
      "handler": {
        "module_path": "examples_py.chatbot_simulation_evaluation.langsmith_agent_simulation_evaluation.nodes",
        "function_name": "chatbot_turn"
      }
    },
    {
      "name": "langsmith_evaluator",
      "handler": {
        "module_path": "examples_py.chatbot_simulation_evaluation.langsmith_agent_simulation_evaluation.nodes",
        "function_name": "run_langsmith_evaluation"
      }
    }
  ],
  "edges": {
    "entry_point": "simulated_user",
    "static_edges": [
      {"from": "simulated_user", "to": "chatbot"},
      {"from": "langsmith_evaluator", "to": "__end__"}
    ],
    "conditional_edges": [
      {
        "from": "chatbot",
        "router": {
          "module_path": "examples_py.chatbot_simulation_evaluation.langsmith_agent_simulation_evaluation.nodes",
          "function_name": "should_continue_simulation"
        },
        "path_map": {
          "continue": "simulated_user",
          "evaluate": "langsmith_evaluator"
        }
      }
    ]
  }
}
